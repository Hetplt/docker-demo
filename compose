version: '3'

services:

  flask-app:
    build: ./app
    container_name: flask-app
    ports:
      - "5000:5000"
    depends_on:
      - mysql

  mysql:
    image: mysql:8
    container_name: mysql-db
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: rootpass
      MYSQL_DATABASE: devopsdb
    ports:
      - "3306:3306"
